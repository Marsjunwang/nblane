# nblane · LLM configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit API keys.

# # --- Required for AI features ---
# LLM_API_KEY=sk

# --- Optional: change to use a different model or provider ---

# # OpenAI (default)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4.1-nano

# Anthropic (via openai-compatible proxy)
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-3-5-sonnet-20241022

# Alibaba DashScope / 阿里云百炼
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-          # 阿里云百炼 API Key (DASHSCOPE_API_KEY)
LLM_MODEL=qwen-plus         # 模型列表: https://help.aliyun.com/model-studio/getting-started/models

# Local Ollama (no key needed, use any string)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:14b
